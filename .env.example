# Notion Integration
# Create an internal Notion integration and share the lead database(s) with it.
# Never commit real values in this file or in any frontend file.

NOTION_TOKEN=secret_your_notion_integration_token

# Preferred: use separate databases for each form.
NOTION_ENQUIRY_DB_ID=your_enquiry_database_id
NOTION_CONTACT_DB_ID=your_contact_database_id

# Alternative: use one shared database for both forms.
# NOTION_DATABASE_ID=your_shared_leads_database_id
# NOTION_DATA_SOURCE_ID=your_shared_notion_data_source_id

# Used to allow browser form requests from your production site.
SITE_URL=https://www.madaoverseas.com
